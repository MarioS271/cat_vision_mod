{
	"schemaVersion": 1,
	"id": "cat_vision",
	"version": "${version}",
	"name": "CatVision",
	"description": "A minecraft mod which gives you Night Vision, even if you aren't a server operator. Inspired by CatEyes by Tee6! :)",
	"authors": [
		"MarioS271"
	],
	"contact": {
		"homepage": "https://modrinth.com/mod/catvisionmod",
		"sources": "https://github.com/MarioS271/cat_vision_mod",
		"issues": "https://github.com/MarioS271/cat_vision_mod/issues"
	},
	"license": "AGPLv3 License",
	"icon": "assets/cat_vision/icon.png",
	"environment": "client",
	"entrypoints": {
		"client": [
			"net.marios271.cat_vision.CatVision"
		],
		"modmenu": [
			"net.marios271.cat_vision.config.ModMenuIntegration"
		]
	},
	"depends": {
		"fabricloader": ">=0.14.0",
		"minecraft": "~26.1",
		"java": ">=21",
		"fabric-api": "*"
	},
	"suggests": {
		"modmenu": "*"
	}
}